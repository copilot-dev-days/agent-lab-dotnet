@using SocOps.Models

<div class="mc-screen mc-overworld-bg">
    <div class="mc-game-shell">
    <header class="mc-hud-header">
        <button
            @onclick="OnReset"
            class="mc-btn mc-btn-ghost mc-btn-sm">
            ← Back
        </button>
        <h1 class="mc-hud-title">Soc Ops</h1>
        <div class="mc-hud-spacer"></div>
    </header>

    <p class="mc-instructions">
        Tap a square when you find someone who matches it.
    </p>

    @if (HasBingo)
    {
        <div class="mc-bingo-banner">
            🎉 BINGO! You got a line!
        </div>
    }

    <div class="mc-board-stage">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
