<div class="mc-modal-backdrop">
    <div class="mc-modal-panel mc-block-panel">
        <div class="mc-modal-icon">⛏️</div>
        <h2 class="mc-modal-title">BINGO!</h2>
        <p class="mc-modal-text">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="mc-btn mc-btn-primary mc-btn-lg w-full">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
