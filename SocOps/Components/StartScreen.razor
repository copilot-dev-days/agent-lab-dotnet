<div class="mc-screen mc-overworld-bg">
    <div class="mc-start-shell">
        <div class="mc-start-card mc-block-panel">
            <h1 class="mc-title mb-2">Soc Ops</h1>
            <p class="mc-subtitle mb-8">Social Bingo</p>

            <div class="mc-rules-card mb-8">
                <h2 class="mc-rules-title mb-3">How to play</h2>
                <ul class="text-left text-sm space-y-2 mc-rules-list">
                <li>• Find people who match the questions</li>
                <li>• Tap a square when you find a match</li>
                <li>• Get 5 in a row to win!</li>
                </ul>
            </div>

            <button
                @onclick="OnStart"
                class="mc-btn mc-btn-primary mc-btn-lg w-full">
                Start Game
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
